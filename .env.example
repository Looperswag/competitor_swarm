# GLM API Configuration
# Get your API key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# Optional: Override default model (GLM-5)
# MODEL_NAME=glm-5

# Optional: Override default base URL
# BASE_URL=https://open.bigmodel.cn/api/anthropic

# Optional: Enable thinking mode (default: true)
# THINKING_MODE=true

# Optional: SDK-level retry count (default: 0)
# LLM_SDK_MAX_RETRIES=0

# Optional: app-level retry count (default: 1)
# LLM_APP_MAX_RETRIES=1

# Tavily Search Configuration (for MCP)
# Get your API key from: https://tavily.com/
# Tavily Remote MCP: https://mcp.tavily.com/mcp/?tavilyApiKey=YOUR_KEY
TAVILY_API_KEY=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
